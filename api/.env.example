# LLM Provider: "groq" (default, fast+free) | "nvidia" | "anthropic"
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...          # groq.com — free tier: 6000 req/min
NVIDIA_API_KEY=nvapi-...      # optional fallback
ANTHROPIC_API_KEY=sk-ant-...  # optional

# Redis (required for Celery queue + WS alerts)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER=redis://localhost:6379/0
CELERY_BACKEND=redis://localhost:6379/1

# API auth key — SDK includes this in X-API-Key header
API_KEY_SECRET=guardiannode-dev-secret

# DB (SQLite default, swap for Postgres in prod)
DATABASE_URL=sqlite:///./guardiannode.db

# CORS — restrict to your frontend domain in prod
CORS_ORIGINS=["*"]
